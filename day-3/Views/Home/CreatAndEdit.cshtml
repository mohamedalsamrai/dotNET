@{
	ViewData["Title"] = "Creat / Edit";
}
@model day_3.Models.Item
<div class="text-center">
	<h1 class="display-4">Creat And Edit</h1>

</div>
<form method="post" asp-action="CreatAndEditForm" asp-controller="Home">
	<input hidden class="form-control" type="number" placeholder="0" asp-for="Id" />
	<label class="mt-4">Value</label>
	<input class="form-control" type="number" placeholder="0" asp-for="Value" />
	<label class="mt-4">Description</label>
	<input class="form-control" type="text" placeholder="Add Description " asp-for="Description" />
	<button class=" btn btn-primary mt-4" type="submit">Ok</button>
</form>